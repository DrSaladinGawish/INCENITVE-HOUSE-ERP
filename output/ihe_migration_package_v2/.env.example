# IHE-ERP Database Connection
# Copy this file to .env and edit with your actual credentials

DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost,1433;DATABASE=IncentiveHouse;UID=sa;PWD=YourStrongPassword;TrustServerCertificate=yes;

